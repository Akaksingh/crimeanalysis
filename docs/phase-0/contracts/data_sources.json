{
  "contract": "data_sources",
  "version": "0.1.0",
  "updated": "2026-06-14",
  "description": "Register of candidate data sources with license, access path, PII level, refresh cadence, and the capability each feeds. This is the legal/access constraints record required by Phase 0 exit criteria. pii_level governs handling under roadmap §9 governance.",
  "pii_levels": {
    "none": "fully aggregated, no individuals (NCRB district counts, census)",
    "low": "geographic only, no persons (boundaries, POIs)",
    "high": "person-level / FIR-level records (offenders, victims) — never from open sources; pilot/MOU only"
  },
  "access_types": {
    "open": "publicly downloadable, free",
    "open_account": "free but requires login (e.g. Kaggle)",
    "mou": "available only under a data-sharing agreement with the police dept",
    "synthetic": "generated locally"
  },
  "sources": [
    {
      "id": "ncrb_cii_tables",
      "name": "NCRB Crime in India — official tables",
      "url": "https://ncrb.gov.in/crime-in-india-table-content.html",
      "owner": "National Crime Records Bureau, MHA",
      "geo_grain": "DISTRICT/STATE/CITY",
      "time_coverage": "annual, ~2001–2023",
      "format": ["pdf", "xlsx"],
      "license": "Government of India open data (attribution)",
      "access": "open",
      "pii_level": "none",
      "refresh": "annual",
      "maps_to": ["trends", "hotspot_density", "district_drilldown", "kpi_cards"],
      "limitations": "Aggregated annual counts; no incident coordinates; PDFs need parsing; legal head changes (IPC->BNS) over time."
