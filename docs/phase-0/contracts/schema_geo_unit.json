{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "geo_unit",
  "title": "Geo Unit",
  "description": "One node in the geographic hierarchy (geo_hierarchy.json). Every incident and kpi_fact references a geo_unit_id.",
  "type": "object",
  "required": ["geo_unit_id", "level", "name"],
  "additionalProperties": false,
  "properties": {
    "geo_unit_id": { "type": "string", "pattern": "^(NATION|STATE|RANGE|DISTRICT|SUBDIVISION|STATION|BEAT):.+", "description": "Globally unique id, e.g. DISTRICT:MH-PUNE-CITY" },
    "level": { "type": "string", "enum": ["NATION", "STATE", "RANGE", "DISTRICT", "SUBDIVISION", "STATION", "BEAT"] },
    "name": { "type": "string" },
    "parent_id": { "type": ["string", "null"], "description": "geo_unit_id of the level above; null for NATION" },
    "codes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lgd_state_code": { "type": ["integer", "null"] },
        "lgd_district_code": { "type": ["integer", "null"] },
        "census_state_code": { "type": ["integer", "null"] },
        "census_district_code": { "type": ["integer", "null"] }
      }
    },
    "centroid": {
      "type": ["object", "null"],
      "required": ["lat", "lon"],
      "additionalProperties": false,
      "properties": {
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "boundary_ref": { "type": ["string", "null"], "description": "Reference/id into the boundary geojson source (e.g. datameet feature id)" },
    "area_km2": { "type": ["number", "null"], "minimum": 0 },
    "population": { "type": ["integer", "null"], "minimum": 0 },
    "female_population": { "type": ["integer", "null"], "minimum": 0 },
    "population_year": { "type": ["integer", "null"], "description": "Vintage of the population figure, e.g. 2011 or projected 2024" }
  }
}
